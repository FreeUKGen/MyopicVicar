<% if preview[:error].present? %>
  <section class="island island--light">
    <p style="color:red"><%= preview[:error] %></p>
    <%= link_to 'Back to register', register_path(register), class: 'btn   btn--small push-half--top' %>
  </section>
<% elsif preview[:no_candidates] %>
  <section class="island island--light">
    <p><%= preview[:message] %></p>
    <%= link_to 'Back to register', register_path(register), class: 'btn   btn--small push-half--top' %>
  </section>
<% else %>
  <% actions = preview[:planned_actions] %>
  <% target = preview[:target] %>

  <section class="island island--light push-half--bottom">
    <h5>Summary — what would happen</h5>
    <ul>
      <li><strong>Keep:</strong> this register (<code><%= target[:id] %></code>)</li>
      <li><strong>Delete:</strong> <%= actions[:registers_to_delete_count] %> duplicate register document(s)
        <% if actions[:registers_to_delete].any? %>
          — <% actions[:registers_to_delete].each_with_index do |rid, i| %><code><%= rid %></code><%= ', ' unless i == actions[:registers_to_delete].size - 1 %><% end %>
        <% end %>
      </li>
      <li><strong>Reassign to this register:</strong>
        <% RegisterMergeService::DEPENDENCY_MODELS.each do |m| %>
          <% n = preview[:totals][m.name].to_i %>
          <% if n.positive? %>
            <%= n %> <%= RegisterMergeService.model_label(m.name).downcase %>;
          <% end %>
        <% end %>
        <strong><%= actions[:csv_entries_reassigned] %></strong> transcription rows (CSV entries) across those batches
      </li>
    </ul>
    <% actions[:notes].each do |note| %>
      <p class="push-half--top"><em><%= note %></em></p>
    <% end %>

    <% if preview[:merge_allowed] %>
      <p style="color: green;"><strong>Dry run result:</strong> merge can proceed — no blocking coordinator metadata on duplicates.</p>
    <% else %>
      <p style="color:red"><strong>Dry run result:</strong> merge is <strong>not safe</strong> until blocked registers are edited or cleared (see below).</p>
    <% end %>
  </section>

  <section class="island island--light push-half--bottom">
    <h5>Target register (kept)</h5>
    <p>Id <code><%= target[:id] %></code> — <%= target[:register_type_label] %>
      <% if target[:alternate_register_name].present? %> — <%= target[:alternate_register_name] %><% end %>
    </p>
    <% if target[:coordinator_fields].any? %>
      <p>Coordinator metadata on target: <%= target[:coordinator_fields].map { |f| f[:label] }.join(', ') %>.</p>
    <% end %>
    <p>Currently linked: <%= target[:csv_entry_count] %> transcription rows on this register.</p>
  </section>

  <% if preview[:blockers].any? %>
    <section class="island island--light push-half--bottom">
      <h5 style="color:red">Blocked — resolve before merging</h5>
      <% preview[:blockers].each do |b| %>
        <% candidate = preview[:candidates].find { |c| c[:id] == b[:id] } %>
        <p>Register <code><%= b[:id] %></code> — <%= b[:block_reason] %></p>
        <% if candidate && candidate[:coordinator_fields].any? %>
          <ul>
            <% candidate[:coordinator_fields].each do |f| %>
              <li><strong><%= f[:label] %>:</strong> <%= f[:value] %></li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <section class="island island--light">
    <h5>Duplicate registers — items that would move or be deleted</h5>

    <table class="table--bordered table--data push-half--bottom">
      <tr>
        <th>Duplicate register id</th>
        <% RegisterMergeService::DEPENDENCY_MODELS.each do |m| %>
          <th><%= RegisterMergeService.model_label(m.name) %></th>
        <% end %>
        <th>Transcription rows</th>
        <th>Status</th>
      </tr>
      <% preview[:candidates].each do |c| %>
        <tr>
          <td><code><%= c[:id] %></code></td>
          <% RegisterMergeService::DEPENDENCY_MODELS.each do |m| %>
            <td><%= c[:dependency_counts][m.name].to_i %></td>
          <% end %>
          <td><%= c[:csv_entry_count] %></td>
          <td><%= c[:blocked] ? 'Blocked' : 'OK' %></td>
        </tr>
      <% end %>
      <tr>
        <th>Totals reassigned</th>
        <% RegisterMergeService::DEPENDENCY_MODELS.each do |m| %>
          <th><%= preview[:totals][m.name].to_i %></th>
        <% end %>
        <th><%= actions[:csv_entries_reassigned] %></th>
        <th></th>
      </tr>
    </table>

    <% preview[:candidates].each do |c| %>
      <div class="push--top" style="border-top: 1px solid #ccc; padding-top: 1em;">
        <h6>Register <code><%= c[:id] %></code> — will be deleted after reassignment</h6>
        <% if c[:alternate_register_name].present? || c[:register_name].present? %>
          <p><%= [c[:alternate_register_name], c[:register_name]].compact.join(' / ') %></p>
        <% end %>

        <% RegisterMergeService::DEPENDENCY_MODELS.each do |model| %>
          <% affected = c[:affected][model.name] %>
          <% next if affected[:total].zero? %>

          <p class="push-half--top"><strong><%= RegisterMergeService.model_label(model.name) %></strong> (<%= affected[:total] %>)</p>
          <ul>
            <% affected[:items].each do |item| %>
              <li>
                <code><%= item[:id] %></code> — <%= item[:label] %>
                <% if item[:detail].present? %> <span class="text--quiet">(<%= item[:detail] %>)</span><% end %>
              </li>
            <% end %>
          </ul>
          <% if affected[:truncated] %>
            <p><em>… and <%= affected[:total] - RegisterMergeService::PREVIEW_ITEM_LIMIT %> more not shown.</em></p>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <p class="push-half--top">
      Confirming will perform the actions in the summary above. This cannot be undone.
    </p>

    <% if preview[:merge_allowed] %>
      <%= button_to 'Confirm merge (not a dry run)',
                    merge_register_path(register),
                    method: :post,
                    class: 'btn   btn--small',
                    data: { turbo: false, confirm: 'Perform the merge now? Duplicate registers will be deleted. This cannot be undone.' } %>
    <% else %>
      <p><strong>Confirm merge</strong> is disabled until every blocked register is edited or cleared.</p>
    <% end %>

    <%= link_to 'Back to register', register_path(register), class: 'btn   btn--small push-half--top', data: { turbo: false } %>
  </section>
<% end %>
