<% breadcrumb :merge_preview_register, @county, @place, @church, @register %>
<% preview = @merge_preview %>
<p style="text-align: center">
  <strong>Dry run:</strong> merge duplicate registers of type <b><%= preview[:register_type_label] %></b>
  for <b><%= @church_name %></b> in <b><%= @place_name %></b> of <b><%= @county %></b>
</p>
<p style="text-align: center; max-width: 42em; margin: 0 auto 1em;">
  Nothing is changed until you confirm. Review the lists below to check the merge is safe.
  Use <strong>Refresh dry run</strong> after editing registers to reload the preview without leaving this page.
</p>
<%= render 'flash_notice' %>
<%= render 'merge_preview_frame', preview: preview, register: @register %>
