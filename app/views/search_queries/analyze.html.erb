<% breadcrumb :search_query_analysis, @search_query %>
<% title "Search Query Analysis" %>
<h1>Performance Analysis</h1>
<h2>Query</h2>
<div>
  <% search_params_for_display(@search_query).each do |name, value| %>
    <%= name %>: <strong><%= value %></strong><br />
  <% end %>
</div>
<h2>Indexes</h2>
<dl>
  <dt>Index hint (passed to MongoDB)</dt>
  <dd><strong><%= @search_index_hint %></strong></dd>
  <dt>Winning plan index (chosen by MongoDB)</dt>
  <dd><strong><%= @search_index_winning_plan.presence || '—' %></strong></dd>
</dl>
<p class="read-length">
  The hint is computed from the search criteria and passed with <code>.hint()</code>.
  The winning plan index is what MongoDB reports in <code>queryPlanner.winningPlan</code>
  for that explain run; it may differ from the hint.
</p>
<h2>Explain Plan</h2>
<% unless @plan_error.blank? %>
  Explain command failed with error <b><%= @plan_error %></b>!<br />
  <br />
  <h3>Unsorted Plan</h3>
<% end %>
<%= debug @plan %>
<h2>Enabled Indexes</h2>
<table>
  <thead>
    <th>
      Index Name
    </th>
    <% SearchRecord.collection.indexes.map {|idx| idx["key"].size}.max.times.each_with_index do |i| %>
      <th>Key <%=i%></th>
    <% end %>
  </thead>
  <tbody>
    <% SearchRecord.collection.indexes.each do |index| %>
      <tr>
        <td>
          <%= index["name"]%>
        </td>
        <% index["key"].keys.each do |key| %>
          <td>
            <%= key %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </table>