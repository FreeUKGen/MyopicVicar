<section>
  <div id="evidence_explained_citation_container" style="display: none;">
    <% @entry = entry %>
    <% protocol = URI.parse(request.original_url).scheme %>
    <% domain = URI.parse(request.original_url).host %>
    <% port = URI.parse(request.original_url).port %>
    <% domain = "#{domain}:#{port}" if domain.present? && port.present? && port != 443 %>
    <h4>Citation (Evidence explained):</h4>
    <p class = "citation_container"><%=appname%> - "GRO Index of <%= format_record_type_for_scan_url(@entry) %>s" database (<%= "#{protocol}://#{domain}#{@url}" %> : accessed <%=Date.today.strftime("%e %b %Y")%>), entry for <%= @entry['GivenName'] %> <%= @entry['Surname'] %>, <%= format_quarter(@entry['QuarterNumber']) %>, <%=@entry['District']%>, Vol.<%=@entry['Volume']%>/<%=@entry['Page']%>, citing General Register Office, Southport</p>
    <div class = "text--center">
      <button class = "btn  btn--small ", onclick = copy("evidence_explained_citation_container") style = "cursor: pointer">Copy</button>
      <button class = "btn  btn--small ", onclick = this.parentElement.parentElement.style.display='none' style = "cursor: pointer">Close</button>
    </div>
</section>
