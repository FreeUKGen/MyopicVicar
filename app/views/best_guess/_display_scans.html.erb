<%# app/views/best_guess/_display_scans.html.erb %>
<div id="display_scans">
  <h4 class="push-half--bottom">Scans</h4>
  <% scan_links, acc_scans, acc_mul_scans = record.get_scans %>
  <% scan_links_array = render_scan_rows(scan_links, acc_scans, acc_mul_scans, record) %>
  <% if scan_links_array.present? && scan_links_array.any? %>
    <% valid_links = scan_links_array.reject { |link| link.blank? || link.to_s.strip.empty? } %>
    <% if valid_links.any? %>
      <ul class="flush--bottom">
        <% valid_links.each do |link| %>
          <%= raw link %>
        <% end %>
      </ul>
    <% end %>
  <% end %>
  <p class="push-half--bottom"><%= raw ERB.new(ApplicationText::SCAN_HELP_TEXT).result(binding) %></p>
</div>
<div id="transcription_errors" data-record-id="<%= record.try(:RecordNumber) || record.try(:[], :RecordNumber) %>">
  <h4 class="push-half--bottom">Transcription Errors</h4>
  <p id="transcription_error_before_scan" class="transcription-error-message">You must view the scan (see above) before you can report a possible error in our transcription of the GRO index. Once you have reviewed the scan, a link will appear here</p>
  <p id="transcription_error_after_scan" class="transcription-error-message" style="display: none;">
  If you think the transcription does not match the scan, you can <%= link_to "submit a report", report_error_contact_path(record.RecordNumber, :query => @search_query), target: "_blank" %> and we will investigate. 
  If we agree that there has been a mistranscription of the GRO index, we will endeavour to correct it in our database (usually within two months).</p>
</div>
<script>
(function() {
  var recordId = document.getElementById('transcription_errors').getAttribute('data-record-id') || 'default';
  var storageKey = 'best_guess_scan_downloaded_' + recordId;
  var beforeEl = document.getElementById('transcription_error_before_scan');
  var afterEl = document.getElementById('transcription_error_after_scan');
  function showAfterScan() {
    if (beforeEl) beforeEl.style.display = 'none';
    if (afterEl) afterEl.style.display = 'block';
  }
  if (sessionStorage.getItem(storageKey)) {
    showAfterScan();
  }
  document.getElementById('display_scans').addEventListener('click', function(e) {
    if (e.target.closest && e.target.closest('a.scan-link')) {
      sessionStorage.setItem(storageKey, '1');
      showAfterScan();
    }
  });
})();
</script>