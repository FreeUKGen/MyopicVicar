<%= render 'flash_notice' %>
<% title "Reference Entry Details" %>
<% print_friendly = (defined?(@printable_format) && @printable_format) ? true : false %>
<% reference_entry_link = ->(opts) { @search ? show_reference_entry_path(opts.merge(search_id: @search_id)) : show_reference_entry_non_search_path(opts) } %>
  <h1 class="accessibility">Reference Entry Informations</h1>
  <%= link_to "#{app_icons[:left_arrow_pink]} Back to Results".html_safe, search_query_path(@search_query, id: @search_id, anchor: @record.record_hash), class: " btn   btn--small" if @search_id.present?%>
  <% unless @record.blank? %>
    <% if @search %>
      <%= link_to "#{app_icons[:left_arrow_pink]} Back to Search Entry".html_safe, friendly_bmd_record_details_path(@search_id, @record.RecordNumber, @record.friendly_url, search_entry: @record.RecordNumber, record_hash: @record.record_hash), class: " btn   btn--small" %>
    <% else %>
      <%= link_to "#{app_icons[:left_arrow_pink]} Back to Entry".html_safe, friendly_bmd_record_details_non_search_path(@record.RecordNumber, @record.friendly_url, record_hash: @record.record_hash), class: " btn   btn--small" %>
    <% end %>
  <% end %>
  <div class="grid">
    <div class="grid__item one-whole lap-one-whole palm-one-whole ">
      <p class="alpha push-half--top project-text-color flush--bottom text--center"><strong><%= "Reference Details of #{@record[:GivenName].upcase} #{@record[:Surname].upcase}" %></strong></p>
      <section>
        <div class="grid__item one-half lap-one-half palm-one-whole">
          <% record_type = RecordType::display_name(@record.RecordTypeID)%>
          <p class="epsilon push-half--top flush--bottom"><strong><%= "Entry Information: #{@record[:GivenName].upcase} #{@record[:Surname].upcase}" %></strong></p>
      <hr>
          <%# if @record.reference_entry_description_text_display? %>
            <p><%#= @referral_record.present? ? ApplicationText::LATE_ENTRY_TEXT_WITH_REFERENCE : ApplicationText::LATE_ENTRY_TEXT_WITHOUT_REFERENCE%></p>
          <%# end %>
          <%#= render partial: 'partial_entry_information_table', locals: {record: @record, entry_type: record_type.downcase, search: false, original_record: @record , type: "reference", search_id: @search_id, more_info: true} %>
          <%= render partial: 'entry_information_table', locals: {record: @record, search: @search, entry_type: record_type.downcase, query: @search_query, search_id: @search_id, original_record: @record, type: "reference"} %>
          <div class="islet islet--bordered">
            <p>More on this entry:</p>
            <%= render partial: 'entry_queries', locals: { record: @record } %>
            <%= render partial: 'display_scans', locals: { record: @record } %>
            <%= render partial: 'display_postems', locals: { record: @record } %>
          </div>
          <div class='push-half--top'>
              <div class="grid__item one-whole">
                <div class='grid__item one-quarter lap-one-quarter palm-one-half'>
                  <% if @primary_previous_record.present?%>
                    <%= link_to 'Previous Referral Entry<i class="fa fa-chevron-right view_arrow"></i> '.html_safe, reference_entry_link.call(entry_id: @record.RecordNumber, primary_referral_number: @primary_previous_record ), class: 'push-half--right push-half--top' unless @primary_previous_record.nil?%>
                  <% end %>
                </div>
                <div class='grid__item one-quarter lap-one-quarter palm-one-half'>
                  <% if @primary_next_record.present?%>
                    <%= link_to 'Next Referral Entry<i class="fa fa-chevron-right view_arrow"></i> '.html_safe, reference_entry_link.call(entry_id: @record.RecordNumber, primary_referral_number: @primary_next_record ), class: 'push-half--right push-half--top' unless @primary_next_record.nil?%>
                  <% end %>
                </div>
              </div>
            </div>
        </div>
      </section>
      <section>
        <div class="grid__item one-half lap-one-half palm-one-whole">
          <% if @secondary_referral_record.present? %>
            <% record_type = RecordType::display_name(@secondary_referral_record.RecordTypeID)%>
            <p class="epsilon push-half--top flush--bottom"><strong><%= "Referal Information: #{@secondary_referral_record[:GivenName].upcase} #{@secondary_referral_record[:Surname].upcase}" %></strong></p>
            <hr>
            <%#= render partial: 'partial_entry_information_table', locals: {record: @secondary_referral_record, entry_type: record_type.downcase, search: false, original_record: @record, type: "reference", search_id: @search_id, more_info: true } %>
            <%= render partial: 'entry_information_table', locals: {record: @secondary_referral_record, search: @search, entry_type: record_type.downcase, query: @search_query, search_id: @search_id, original_record: @record, type: "reference"} %>
            <div class="islet islet--bordered">
              <p>More on this entry:</p>
              <%= render partial: 'entry_queries', locals: { record: @secondary_referral_record } %>
              <%= render partial: 'display_scans', locals: { record: @secondary_referral_record } %>
              <%= render partial: 'display_postems', locals: { record: @secondary_referral_record } %>
            </div>
              <div class='push-half--top'>
                <div class="grid__item one-whole">
                  <div class='grid__item one-half lap-one-half palm-one-whole'>
                    <% if @secondary_previous_record.present?%>
                      <%= link_to 'Previous Referral Entry<i class="fa fa-chevron-right view_arrow"></i> '.html_safe, reference_entry_link.call(entry_id: @primary_array.first, secondary_referral_number: @secondary_previous_record ), class: 'push-half--right push-half--top' unless @secondary_previous_record.nil?%>
                    <% end %>
                  </div>
                  <div class='grid__item one-half lap-one-half palm-one-whole'>
                    <% if @secondary_next_record.present?%>
                      <%= link_to 'Next Referral Entry<i class="fa fa-chevron-right view_arrow"></i> '.html_safe, reference_entry_link.call(entry_id: @primary_array.first, secondary_referral_number: @secondary_next_record ), class: 'push-half--right push-half--top' unless @secondary_next_record.nil?%>
                    <% end %>
                  </div>
                </div>
              </div>
          <% else %>
            <p>No reference</p>
          <% end %>
        </div>
      </section>
    </div>
  </div>
