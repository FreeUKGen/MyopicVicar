<section>
  <div id="wikitree_inline_citation_container" style="display: none;">
    <% @entry = entry %>
    <% protocol = URI.parse(request.original_url).scheme %>
    <% domain = URI.parse(request.original_url).host %>
    <% port = URI.parse(request.original_url).port %>
    <% domain = "#{domain}:#{port}" if domain.present? && port.present? && port != 443 %>
  <h4>Citation (embedded Wikitree citation):</h4>
  <p class = "citation_container">
    &lt;ref&gt;"<%=appname%> Search", online database. GRO Index of <%= format_record_type_for_scan_url(@entry)%>s,
    <%= format_quarter(@entry['QuarterNumber']) %>, <%=@entry['District']%> Registration District, Volume <%=@entry['Volume']%> Page <%=@entry['Page']%>
    <%= "[#{protocol}://#{domain}#{@url} " %>
    <%= format_record_type_for_scan_url(@entry) %> of <%= @entry['GivenName'] %> <%= @entry['Surname'] %>
    <% if @entry[:RecordTypeID] == 1 %>
      <% if @entry['AssociateName'].present? %>
        : Mother's maiden name <%= @entry['AssociateName'] %>
      <% end %>
    <% elsif @entry[:RecordTypeID] == 2 %>
      <% if @entry['AgeAtDeath'].present? %>
        : Age at death <%= @entry['AgeAtDeath'].to_s %>
      <% end %>
    <% elsif @entry[:RecordTypeID] == 3 %>
      <% if @entry['AssociateName'].present? %>
        : Spouse's surname <%= @entry['AssociateName'] %>
      <% end %>
    <% end %>
    ]. Viewed <%=Date.today.strftime("%e %b %Y")%>
    &lt;/ref&gt;
  </p>
    <div class = "text--center">
      <button class = "btn  btn--small ", onclick = copy("wikitree_inline_citation_container") style = "cursor: pointer">Copy</button>
      <button class = "btn  btn--small ", onclick = this.parentElement.parentElement.style.display='none' style = "cursor: pointer">Close</button>
    </div>
</section>
