<script>
   var mobile = (/iphone|ipod|android|blackberry|mini|windows\sce|palm/i.test(navigator.userAgent.toLowerCase()));  
    if (mobile) { 
        $('#theFixed').hide();
    } 
    else 
    { 
    
        var offsetPixels = 350; 

	$(window).scroll(function() {
		if ($(window).scrollTop() > offsetPixels && $(window).scrollTop() < 1000) {
			$( "#theFixed" ).css({
				"position": "fixed",
				"top": "15px"
			});
		} else {
                  $( "#theFixed" ).css({
	            "position": "static"
	          });
                }
	});
     }
</script>
