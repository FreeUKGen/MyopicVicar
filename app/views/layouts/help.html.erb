<%# Help layout (scoped to HelpController). Minimal sticky sidebar + one overflow override. %>

<% unless content_for?(:sidebar) %>
  <% content_for :sidebar do %>
    <div class="help-layout-sidebar">
      <%= Help.create_help_menu(Help::TopLevelPages, 'Help topics') %>

      <div class="help-layout-ad push-half--top" aria-label="Advertisement">
        <h2 class="title-block help-layout-ad__title">Advertisement</h2>
        <!-- GAM 71161633/FRBMD_freebmd2orguk/Vrec_Sticky -->
        <div data-fuse="Vrec_Sticky"></div>
      </div>
    </div>
  <% end %>
<% end %>

<p class="lead">Struggling to use FreeBMD? Not finding someone you expected to find? Not sure what to do next? This help section contains answers to common problems, and has links to more detailed information.</p>
<%= yield %>

<style>
  /* Sticky is blocked by `.grid { overflow:hidden; }` in the grid system.
     Override it on help pages (this style tag is only rendered for help). */
  #bmd_site_content .container > .grid { overflow: visible !important; }

  .help-layout-ad__title { text-align: center; }
  .help-layout-sidebar { position: sticky; top: 0; align-self: flex-start; }
  .help-layout-sidebar .grid__item,
  .help-layout-sidebar .float--right { float: none !important; width: auto !important; max-width: none !important; }
  @media (max-width: 720px) { .help-layout-sidebar { position: static; top: auto; } }
</style>

