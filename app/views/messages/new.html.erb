<% new_breadcrumb(@message, params[:id])  %>
<br>
<h4 style="text-align: center"><%= new_title(@respond_to_message, params[:id])%></h4>
<% if params[:id].present? %>
  <p style="text-align: center">This reply will go to the sender of the original message</p>
  <%= render 'reply'%>
<% else %>
  <%= message_synicate_coordinator_first_reminder %>
  <% if params[:source] == 'gazetteer' && session[:gazetteer_recipient].present? %>
    <p style="text-align: center"><strong>This message will be sent to the County Coordinator for the Gazetteer entry.</strong></p>
  <% end %>
  <%= render 'form' %>
<% end %>