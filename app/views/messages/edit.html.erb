<% edit_breadcrumb(@message) %>
<br>
<h4 style="text-align: center"><%= edit_title %> <%= @message.identifier %> for <%= @message.userid%> with subject "<%= @message.subject%>"</h4>
<%= render 'flash_notice' %>
<%= simple_form_for  @message   do |f| %>
  <%# Optional: pass-through params for Gazetteer communicate flow %>
  <% if params[:next].present? %>
    <%= hidden_field_tag :next, params[:next] %>
    <%= hidden_field_tag :role, params[:role] %>
    <%= hidden_field_tag :allowed_chapmans, params[:allowed_chapmans] %>
    <%= hidden_field_tag :source, params[:source] %>
  <% end %>
  <%= f.input :body, :label => "Message ",as: :text, :input_html => { :rows => 15, :style => 'width: 100%' , :placeholder => @message.body} %>
  <%= f.button :submit, 'Save'   %>
<% end %>