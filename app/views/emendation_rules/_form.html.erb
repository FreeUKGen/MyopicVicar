<%= form_with(model: emendation_rule, local: true) do |form| %>
  <% if emendation_rule.errors.any? %>
    <div class="alert alert--negative">
      <h2 class="epsilon"><%= pluralize(emendation_rule.errors.count, "error") %> prohibited this rule from being saved:</h2>
      <ul>
      <% emendation_rule.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid">
    <div class="grid__item one-third lap-one-half palm-one-whole push--bottom">
      <%= form.label :emendation_type_id, "Emendation Category (Type)" %>
      <%= form.collection_select :emendation_type_id, EmendationType.all, :id, :name, { prompt: "Select a Type" }, { class: "text-input" } %>
    </div>
    
    <div class="grid__item one-third lap-one-half palm-one-whole push--bottom">
      <%= form.label :original, "Abbreviation / Original Text" %>
      <%= form.text_field :original, class: "text-input" %>
      <small class="text--muted">Example: wm</small>
    </div>

    <div class="grid__item one-third lap-one-half palm-one-whole push--bottom">
      <%= form.label :replacement, "Replacement Text" %>
      <%= form.text_field :replacement, class: "text-input" %>
      <small class="text--muted">Example: william</small>
    </div>

    <div class="grid__item one-third lap-one-half palm-one-whole push--bottom">
      <%= form.label :gender, "Gender Filter (Optional)" %>
      <%= form.select :gender, options_for_select([['Applies to Both', nil], ['Male (m)', 'm'], ['Female (f)', 'f']], emendation_rule.gender), {}, { class: "text-input" } %>
    </div>
  </div>

  <div class="push--top">
    <%= form.submit class: "btn" %>
    <%= link_to 'Cancel', emendation_rules_path, class: "btn btn--negative" %>
  </div>
<% end %>
