<h1 class="title">Errors and omissions in the <%= gro_abbrev_html %> Index data</h1>
<% if flash[:notice] %>
  <div id="notice" style="color:blue"><br>
    <%= flash[:notice] %>  <% flash[:notice] = nil%><br>
  </div>
<% end %>
<% if @contact.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@contact.errors.count, "error") %> prohibited your contact from being submitted:</h2>
    <ul class="validation-list">
      <% @contact.errors.full_messages.each do |msg| %>
        <li class="validation-list__error"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<div class="grid" >
  <p class="grid__item push-half--bottom desk-wide-three-quarters desk-three-quarters lap-one-whole palm-one-whole">The data in the FreeBMD website is transcribed by our volunteers from scans of pages in the General Register Office(<%= gro_abbrev_html %>) indexes. These indexes were created by copying selected information from certificates, pooling it centrally, and creating an index by hand. The format of these indexes has changed over time, from handwritten pages, to typed pages, then to computer printout. The quality of the scans we have been given access to (often a scan of fiche or microfilm, which is itself a copy of the source page) has also varied - some are very hard to read.</p>
  <p class="grid__item push-half--bottom desk-wide-three-quarters desk-three-quarters lap-one-whole palm-one-whole">Please select the option below which best describes your reason for thinking the data in this entry is wrong, and an explanation will appear, advising what (if anything) you should report to us.</p>
</div>
  <div class="push--bottom">
  <ol class="grid">
    <li class="grid__item one-half lap-one-whole palm-one-whole" id="section_select_li">
      <label class="ttip" for="report_error_section" tabindex="0">Select section</label>
      <select id="report_error_section" class="text-input" aria-describedby="section_help">
        <option value="">Please choose a section</option>
        <% FreebmdDataProblem::REPORT_ERROR_SECTIONS.each_with_index do |section, idx| %>
          <option value="<%= idx %>"><%= section[:title] %></option>
        <% end %>
      </select>
      <span id="section_help" class="help-text">Then open a subsection below to read the explanation.</span>
    </li>
    <li class="grid__item desk-wide-three-quarters desk-three-quarters lap-one-whole palm-one-whole clear--left" id="subsections_li" style="display: none;">
      <label class="ttip" tabindex="0">Subsections</label>
      <div id="subsections_accordion" class="report-error-accordion" role="region" aria-label="Subsections and explanations">
        <% FreebmdDataProblem::REPORT_ERROR_SECTIONS.each_with_index do |section, section_idx| %>
          <div class="accordion-section" data-section-index="<%= section_idx %>" style="display: none;">
            <% section[:subsections].each do |sub| %>
              <% if sub[:children].present? %>
                <div class="accordion-nested-group" role="group" aria-label="<%= gro_abbrev_plain_in_text(sub[:label]).truncate(120) %>">
                  <p class="accordion-nested-group__heading"><%= gro_abbrev_in_user_text(sub[:label]) %></p>
                  <% sub[:children].each do |leaf| %>
                    <% form_numbers = Array(leaf[:form_numbers]).map(&:to_i) %>
                    <%# Match JS: form blocks 1/3/4 live in the main form host; 2 is corrections only. %>
                    <% show_form_1 = leaf[:show_form] || form_numbers.include?(1) || form_numbers.include?(3) || form_numbers.include?(4) %>
                    <details class="accordion-item"
                             data-subsection-id="<%= leaf[:id] %>"
                             data-show-form="<%= show_form_1 ? '1' : '0' %>"
                             data-form-numbers="<%= form_numbers.join(',') %>">
                      <summary class="accordion-item__summary"><%= gro_abbrev_in_user_text(leaf[:label]) %></summary>
                      <div class="accordion-item__body answer_explanations">
                        <% if show_form_1 %>
                          <div class="report-error-explanation-and-form">
                            <%= render_report_error_answer(leaf[:answer]) %>
                            <div class="report_form_host push--top"></div>
                          </div>
                        <% else %>
                          <%= render_report_error_answer(leaf[:answer]) %>
                        <% end %>
                      </div>
                    </details>
                  <% end %>
                </div>
              <% else %>
                <% form_numbers = Array(sub[:form_numbers]).map(&:to_i) %>
                <%# Match JS: form blocks 1/3/4 use report_form_host; without this, only [4] omits the host. %>
                <% show_form_1 = sub[:show_form] || form_numbers.include?(1) || form_numbers.include?(3) || form_numbers.include?(4) %>
                <details class="accordion-item"
                         data-subsection-id="<%= sub[:id] %>"
                         data-show-form="<%= show_form_1 ? '1' : '0' %>"
                         data-form-numbers="<%= form_numbers.join(',') %>">
                  <summary class="accordion-item__summary"><%= gro_abbrev_in_user_text(sub[:label]) %></summary>
                  <div class="accordion-item__body answer_explanations">
                    <% if show_form_1 %>
                      <div class="report-error-explanation-and-form">
                        <%= render_report_error_answer(sub[:answer]) %>
                        <div class="report_form_host push--top"></div>
                      </div>
                    <% else %>
                      <%= render_report_error_answer(sub[:answer]) %>
                    <% end %>
                  </div>
                </details>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </li>
  </ol>
</div>
<div id="report_form_block" class="report_form" style="display: none;">
  <%# Submitted markup split by FreeBMD form_numbers — see lib/freebmd_data_problem.rb and contacts/report_error/* partials %>
  <%= semantic_form_for(@contact, html: { multipart: true }) do |f| %>
    <%= render 'contacts/report_error/form_hidden_fields', f: f %>
    <%= render 'contacts/report_error/form_block_corrections_table' %>
    <%= render 'contacts/report_error/form_block_missing_entry_details' %>
    <%= render 'contacts/report_error/form_block_main_contact', f: f %>
  <% end %>
</div>
<style type="text/css">
  /* Submit Report: Ladda/search-button styles often set a fixed min-width; use intrinsic width */
  #report_error_submit.report-error-form__submit {
    width: unset;
    padding-right: 10px;
    padding-left: 10px;
  }
  .report-error-accordion .accordion-section { margin-top: 1rem; }
  .report-error-accordion .accordion-item { border: 1px solid #ccc; margin-bottom: 0.5rem; border-radius: 4px; transition: background-color 0.15s ease; }
  .report-error-accordion .accordion-item:hover { background-color: #f4f4f4; }
  /* Keyboard: whole row reads as “active” when summary or content inside has focus */
  .report-error-accordion .accordion-item:focus-within { background-color: #f4f4f4; }
  .report-error-accordion .accordion-item__summary { padding: 0.75rem 1rem; cursor: pointer; font-weight: 500; list-style: none; }
  .report-error-accordion .accordion-item__summary:hover { background-color: #f4f4f4; }
  .report-error-accordion .accordion-item__summary:focus { outline: none; }
  .report-error-accordion .accordion-item__summary:focus-visible {
    outline: 2px solid rgb(0, 95, 204);
    outline-offset: 2px;
  }
  .report-error-accordion .accordion-item__summary::-webkit-details-marker { display: none; }
  .report-error-accordion .accordion-item__summary::before { content: "\25b6\00a0"; }
  .report-error-accordion .accordion-item[open] .accordion-item__summary::before { content: "\25bc\00a0"; }
  .report-error-accordion .accordion-item__body { padding: 0 1rem 1rem; border-top: 1px solid #eee; }
  .report-error-accordion .answer_explanations { margin-top: 0.5rem; }
  .report-error-accordion .accordion-nested-group {
    margin-bottom: 0.75rem;
    padding: 0.25rem 0 0.25rem 0.75rem;
    border-left: 3px solid #ccc;
    transition: border-left-color 0.15s ease;
  }
  /* Group cue only: full-width #f4f4f4 on the parent made every sibling <details> look hovered. */
  .report-error-accordion .accordion-nested-group:has(.accordion-item:hover),
  .report-error-accordion .accordion-nested-group:has(.accordion-item:focus-within) {
    border-left-color: #c84182;
  }
  .report-error-accordion .accordion-nested-group__heading { font-weight: 600; margin: 0.35rem 0 0.6rem; line-height: 1.35; }
  .report-error-accordion .accordion-nested-group .accordion-item { margin-left: 0; }
  /* Match FreeBMD corrections table / form block width (see partial max-width 48rem). */
  .report-error-explanation-and-form {
    max-width: 48rem;
    width: 100%;
  }
  /* Form block 3 (missing entry): half-width pairs so placeholders/readable text aren’t cramped in quarters. */
  #section3_required_fields_block .grid__item { min-width: 0; }
  #section3_required_fields_block .text-input {
    overflow: visible;
    text-overflow: clip;
  }
</style>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.0/jquery.validate.min.js"></script>
<script type="text/javascript">
  $(document).ready(function() {
    var $sectionSelect = $('#report_error_section');
    var $subsectionsLi = $('#subsections_li');
    var $accordionSections = $('.accordion-section');
    var $readAnswer = $('.read_answer');
    var $queryInput = $('input[name="contact[query]"]');
    var $correctionsBlock = $('#freebmd_corrections_table_block');
    var $reportFormBlock = $('#report_form_block');
    var $scanUrlInput = $('#contact_scan_url');
    var $section3Block = $('#section3_required_fields_block');
    var $section3RequiredFields = $('.section3-required-field');
    var $section3RequiredCheckbox = $('.section3-required-checkbox');
    var $bodyInput = $('#contact_report_body');
    var $bodyLabel = $('#contact_report_body_label');
    var defaultBodyLabel = 'Additional comments (optional)';
    var defaultBodyPlaceholder = 'Anything else we should know (optional if you filled corrections above).';
    var issueBodyLabel = 'Describe issue';
    var issueBodyPlaceholder = 'Please describe the issue in detail. Line breaks and spacing will be preserved.';

    function setDescribeIssueMode(enabled) {
      if ($bodyLabel.length) $bodyLabel.text(enabled ? issueBodyLabel : defaultBodyLabel);
      if ($bodyInput.length) {
        $bodyInput.attr('placeholder', enabled ? issueBodyPlaceholder : defaultBodyPlaceholder);
        $bodyInput.prop('required', enabled);
      }
    }

    function updateSection3ConditionalFields() {
      var ev = ($('#section3_event').val() || '').toLowerCase();
      var yr = parseInt($('#section3_year').val(), 10);
      var yOk = !isNaN(yr);
      $('.section3-if-birth').toggle(ev === 'birth');
      $('.section3-if-death').toggle(ev === 'death');
      $('.section3-if-marriage').toggle(ev === 'marriage');
      var m1994 = ev === 'marriage' && yOk && yr >= 1994;
      $('.section3-if-marriage1994').toggle(m1994);
      // Quarterly birth/death index rows sometimes include a Registered column — marriage pages (including pre-1994 such as 1966) rarely use this generic slot; marriages from 1994+ use Marriage submission-* fields instead.
      var showRegisteredExtra = ev === 'birth' || ev === 'death';
      $('.section3-if-registered-extra').toggle(showRegisteredExtra);
      // Entry/line applies to birth/death index rows only; marriage (any year) omits it — and with Event still "Please select" we must not show it (ev === '' would satisfy ev !== 'marriage' and wrongly revealed the field before).
      var showEntryOrLineColumn = ev === 'birth' || ev === 'death';
      $('.section3-if-entry-or-line').toggle(showEntryOrLineColumn);
    }

    $('#section3_event, #section3_year').on('change input', updateSection3ConditionalFields);

    function setSection3RequiredState(enabled) {
      if ($section3Block.length) $section3Block.toggle(enabled);
      // Missing-entry details are optional
      if ($section3RequiredFields.length) $section3RequiredFields.prop('required', false);
      if ($section3RequiredCheckbox.length) $section3RequiredCheckbox.prop('required', false);
      if (!enabled && $section3Block.length) {
        $section3Block.find('input[type=text]').val('');
        $section3Block.find('select').val('');
        $section3Block.find('input[type=checkbox]').prop('checked', false);
      }
      updateSection3ConditionalFields();
    }

    updateSection3ConditionalFields();

    $sectionSelect.on('change', function() {
      var sectionIdx = $(this).val();
      $accordionSections.hide();
      $readAnswer.hide();
      $('#read_explanation').prop('checked', false);
      if ($queryInput.length) $queryInput.val('');
      if ($correctionsBlock.length) $correctionsBlock.hide();
      setSection3RequiredState(false);
      setDescribeIssueMode(false);
      if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
      if (sectionIdx === '') {
        $subsectionsLi.hide();
        $('details.accordion-item').attr('open', false);
        return;
      }
      $subsectionsLi.show();
      $accordionSections.filter('[data-section-index="' + sectionIdx + '"]').show();
    });

    function handleAccordionToggle(details) {
      var $details = $(details);
      var subsectionId = $details.data('subsection-id');
      var formNumbersRaw = String($details.data('form-numbers') || '');
      var formNumbers = formNumbersRaw
        .split(',')
        .map(function(v) { return $.trim(String(v)); })
        .filter(function(v) { return v.length > 0; });
      var showForm1 = formNumbers.indexOf('1') !== -1;
      var showForm2 = formNumbers.indexOf('2') !== -1;
      var showForm3 = formNumbers.indexOf('3') !== -1;
      var showForm4 = formNumbers.indexOf('4') !== -1;

      // Enforce a single-open accordion within the visible section.
      if (details.open) {
        $details.closest('.accordion-section').find('details.accordion-item').not(details).prop('open', false);
      }

      if (details.open) {
        if ($queryInput.length) $queryInput.val(subsectionId);
        // Backward compatibility: old config may only set `show_form: true`.
        var showForm = String($details.data('show-form')) === '1';
        if (showForm && formNumbers.length === 0) {
          // Legacy behavior: `show_form: true` used to display both the main form
          // and the corrections table block.
          showForm1 = true;
          showForm2 = true;
        }
        // Form 3/4 live inside Form 1 block; if requested, ensure Form 1 is shown.
        if (showForm3) showForm1 = true;
        if (showForm4) showForm1 = true;
        if (showForm1) {
          $readAnswer.show();
          if ($reportFormBlock.length) {
            var $host = $details.find('.report_form_host').first();
            if ($host.length) {
              $reportFormBlock.appendTo($host).show();
            } else {
              $reportFormBlock.hide();
            }
          }
          // Attach last clicked scan URL (if we have it) to the form submission.
          if ($scanUrlInput.length) {
            var recordId = $('input[name="contact[record_id]"]').val() || 'default';
            var lastScanUrlKey = 'best_guess_last_scan_url_' + recordId;
            var lastScanUrl = null;
            try { lastScanUrl = sessionStorage.getItem(lastScanUrlKey); } catch (e) { lastScanUrl = null; }
            if (lastScanUrl) $scanUrlInput.val(lastScanUrl);
          }
          setSection3RequiredState(showForm3);
          setDescribeIssueMode(showForm4);
          if ($correctionsBlock.length) $correctionsBlock.toggle(showForm2);
        } else {
          $readAnswer.hide();
          $('#read_explanation').prop('checked', false);
          if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
          setSection3RequiredState(false);
          setDescribeIssueMode(false);
          if ($correctionsBlock.length) $correctionsBlock.hide();
        }
      } else {
        // If the user closes the currently-selected subsection, clear selection UI.
        if ($queryInput.length && String($queryInput.val()) === String(subsectionId)) {
          $queryInput.val('');
          $readAnswer.hide();
          $('#read_explanation').prop('checked', false);
          if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
          setSection3RequiredState(false);
          setDescribeIssueMode(false);
          if ($correctionsBlock.length) $correctionsBlock.hide();
        }
      }
    }

    // 'toggle' on <details> does not reliably bubble; bind directly.
    $('details.accordion-item').each(function() {
      this.addEventListener('toggle', function() { handleAccordionToggle(this); });
    });

    // Keep existing behaviour: checkbox can collapse/expand the form if shown.
    $('#read_explanation').change(function() {
      if ($reportFormBlock.length) $reportFormBlock.toggle();
    });

    // Match FreeBMD search form submit (ladda contract spinner).
    var $reportSubmit = $('#report_error_submit');
    if ($reportSubmit.length && typeof Ladda !== 'undefined') {
      $reportSubmit.on('click', function() {
        var l = Ladda.create(this);
        l.start();
      });
    }
  });
</script>