<h1 class="title">Errors and omissions in the GRO Index data</h1>
<% if flash[:notice] %>
  <div id="notice" style="color:blue"><br>
    <%= flash[:notice] %>  <% flash[:notice] = nil%><br>
  </div>
<% end %>
<% if @contact.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@contact.errors.count, "error") %> prohibited your contact from being submitted:</h2>
    <ul class="validation-list">
      <% @contact.errors.full_messages.each do |msg| %>
        <li class="validation-list__error"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<div >
  <p class="push-half--bottom read-length">The data in the FreeBMD website is transcribed by our volunteers from scans of pages in the General Register Office indexes. These indexes were created by copying selected information from certificates, pooling it centrally, and creating an index by hand. The format of these indexes has changed over time, from handwritten pages, to typed pages, then to computer printout. The quality of the scans we have been given access to (often a scan of fiche or microfilm, which is itself a copy of the source page) has also varied - some are very hard to read.</p>
  <p class="push-half--bottom read-length">Please select the option below which best describes your reason for thinking the data in this entry is wrong, and an explanation will appear, advising what (if anything) you should report to us.</p>
</div>
  <div class="push palm-flush--bottom">
  <ol class="grid">
    <li class="grid__item one-half lap-one-whole palm-one-whole" id="section_select_li">
      <label class="ttip" for="report_error_section" tabindex="0">Select section</label>
      <select id="report_error_section" class="text-input" aria-describedby="section_help">
        <option value="">Please choose a section</option>
        <% FreebmdDataProblem::REPORT_ERROR_SECTIONS.each_with_index do |section, idx| %>
          <option value="<%= idx %>"><%= section[:title] %></option>
        <% end %>
      </select>
      <span id="section_help" class="help-text">Then open a subsection below to read the explanation.</span>
    </li>
    <li class="grid__item one-whole lap-one-whole palm-one-whole clear--left" id="subsections_li" style="display: none;">
      <label class="ttip" tabindex="0">Subsections</label>
      <div id="subsections_accordion" class="report-error-accordion" role="region" aria-label="Subsections and explanations">
        <% FreebmdDataProblem::REPORT_ERROR_SECTIONS.each_with_index do |section, section_idx| %>
          <div class="accordion-section" data-section-index="<%= section_idx %>" style="display: none;">
            <% section[:subsections].each do |sub| %>
              <details class="accordion-item" data-subsection-id="<%= sub[:id] %>" data-show-form="<%= sub[:show_form] ? '1' : '0' %>">
                <summary class="accordion-item__summary"><%= sub[:label] %></summary>
                <div class="accordion-item__body answer_explanations">
                  <%= render_report_error_answer(sub[:answer]) %>
                  <% if sub[:show_form] %>
                    <div class="report_form_host push--top"></div>
                  <% end %>
                </div>
              </details>
            <% end %>
          </div>
        <% end %>
      </div>
    </li>
  </ol>
</div>
<div id="report_form_block" class="push palm-flush--bottom report_form" style="display: none;">
  <%= semantic_form_for(@contact, :html => {:multipart => true}) do |f| %>
    <%= f.hidden_field :query %>
    <%= f.hidden_field :contact_type %>
    <%= f.hidden_field :contact_time %>
    <%= f.hidden_field :record_id %>
    <%= f.hidden_field :entry_id %>
    <%= f.hidden_field :line_id %>  
    <%= f.hidden_field :previous_page_url %>
    <%= f.hidden_field :county %>
    <%= f.hidden_field :problem_page_url %>
    <%= hidden_field_tag 'contact[session_data][scan_url]', nil, id: 'contact_scan_url' %>
    <div id="freebmd_corrections_table_block" style="display: none;" class="push--bottom">
      <p class="push-half--bottom">Please enter corrections only for fields that are wrong.</p>
      <% if defined?(@freebmd_record) && @freebmd_record.present? %>
        <%= render partial: 'contacts/freebmd_entry_information_corrections_table', locals: { record: @freebmd_record } %>
      <% else %>
        <p>Current details are not available for this entry.</p>
      <% end %>
    </div>
    <div id="section3_required_fields_block" style="display: none;" class="push--bottom">
      <h3 class="gamma push-half--bottom">Required details for missing entry report</h3>
      <ol class="grid">
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_event">Event</label>
          <select id="section3_event" name="contact[session_data][section3][event]" class="text-input section3-required-field">
            <option value="">Please select</option>
            <option value="Birth">Birth</option>
            <option value="Death">Death</option>
            <option value="Marriage">Marriage</option>
          </select>
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_year">Year</label>
          <input id="section3_year" name="contact[session_data][section3][year]" type="text" class="text-input section3-required-field" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="e.g. 1891">
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_quarter">Quarter (if relevant)</label>
          <select id="section3_quarter" name="contact[session_data][section3][quarter]" class="text-input">
            <option value="">Not applicable</option>
            <option value="Mar">Mar</option>
            <option value="Jun">Jun</option>
            <option value="Sep">Sep</option>
            <option value="Dec">Dec</option>
          </select>
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_surname">Surname</label>
          <input id="section3_surname" name="contact[session_data][section3][surname]" type="text" class="text-input section3-required-field">
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole clear--left">
          <label class="label" for="section3_forename">Forename</label>
          <input id="section3_forename" name="contact[session_data][section3][forename]" type="text" class="text-input section3-required-field">
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_district">District</label>
          <input id="section3_district" name="contact[session_data][section3][district]" type="text" class="text-input section3-required-field">
        </li>
        <li class="grid__item one-quarter lap-one-half palm-one-whole">
          <label class="label" for="section3_page_number">Page number</label>
          <input id="section3_page_number" name="contact[session_data][section3][page_number]" type="text" class="text-input section3-required-field">
        </li>
        <li class="grid__item one-whole push-half--top">
          <label for="section3_multiple_entries">
            <input id="section3_multiple_entries" type="checkbox" name="contact[session_data][section3][multiple_entries]" value="1" class="section3-required-checkbox">
            Multiple entries
          </label>
        </li>
      </ol>
    </div>
    <ol class="grid">
      <li class="grid__item one-quarter lap-one-half palm-one-whole clear--left" id="name_input">
        <label class="label ttip" for="name" tabindex="0">Your name</label>
        <% if @contact.name.nil? %>
          <input id="name" name="contact[name]" type="text" class="text-input" placeholder="Required" required="required">
        <% else %>
          <input id="name" name="contact[name]" type="text" class="text-input" value="<%=@contact.name%>">
        <% end %>
      </li>
      <li class="grid__item one-quarter lap-one-half palm-one-whole" id="email_address_input">
        <label class="label ttip" for="email_address" tabindex="0">Your email address</label>
        <% if @contact.email_address.nil? %>
          <input id="email_address" name="contact[email_address]" type="text" class="text-input" placeholder="Required" required="required">
        <% else%>
          <input id="email_address" name="contact[email_address]" type="text" class="text-input" value="<%=@contact.email_address%>">
        <% end%>
      </li>
      <li class="grid__item one-third lap-three-fifths lap-clear--left palm-one-whole push--bottom">
        <label class="ttip" for="screenshot" tabindex="0">Screenshot or image</label>
        <input class="push--bottom" id="screenshot" name="contact[screenshot]" type="file">
      </li>
      <%= f.action :submit, :as  => :input, :label => 'Report Error' , :button_html => { :class => "btn" }, :wrapper_html => { :class => "grid__item  one-third lap-two-fifths palm-one-whole push--bottom" } %>
      <li class="betterstyling">
        <label for="contact_name_confirm">Please add your name again:</label>
        <input id="contact_name_confirm" type="text" name="contact[contact_name]">
      </li>
    </ol>
  <% end %>
</div>
<style>
  .report-error-accordion .accordion-section { margin-top: 1rem; }
  .report-error-accordion .accordion-item { border: 1px solid #ccc; margin-bottom: 0.5rem; border-radius: 4px; }
  .report-error-accordion .accordion-item__summary { padding: 0.75rem 1rem; cursor: pointer; font-weight: 500; list-style: none; }
  .report-error-accordion .accordion-item__summary::-webkit-details-marker { display: none; }
  .report-error-accordion .accordion-item__summary::before { content: "\25b6\00a0"; }
  .report-error-accordion .accordion-item[open] .accordion-item__summary::before { content: "\25bc\00a0"; }
  .report-error-accordion .accordion-item__body { padding: 0 1rem 1rem; border-top: 1px solid #eee; }
  .report-error-accordion .answer_explanations { margin-top: 0.5rem; }
</style>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.0/jquery.validate.min.js"></script>
<script type="text/javascript">
  $(document).ready(function() {
    var $sectionSelect = $('#report_error_section');
    var $subsectionsLi = $('#subsections_li');
    var $accordionSections = $('.accordion-section');
    var $readAnswer = $('.read_answer');
    var $queryInput = $('input[name="contact[query]"]');
    var $correctionsBlock = $('#freebmd_corrections_table_block');
    var $reportFormBlock = $('#report_form_block');
    var $scanUrlInput = $('#contact_scan_url');
    var $section3Block = $('#section3_required_fields_block');
    var $section3RequiredFields = $('.section3-required-field');
    var $section3RequiredCheckbox = $('.section3-required-checkbox');

    function setSection3RequiredState(enabled) {
      if ($section3Block.length) $section3Block.toggle(enabled);
      if ($section3RequiredFields.length) $section3RequiredFields.prop('required', enabled);
      if ($section3RequiredCheckbox.length) $section3RequiredCheckbox.prop('required', enabled);
      if (!enabled) {
        $section3RequiredFields.val('');
        $section3RequiredCheckbox.prop('checked', false);
      }
    }

    $sectionSelect.on('change', function() {
      var sectionIdx = $(this).val();
      $accordionSections.hide();
      $readAnswer.hide();
      $('#read_explanation').prop('checked', false);
      if ($queryInput.length) $queryInput.val('');
      if ($correctionsBlock.length) $correctionsBlock.hide();
      setSection3RequiredState(false);
      if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
      if (sectionIdx === '') {
        $subsectionsLi.hide();
        $('details.accordion-item').attr('open', false);
        return;
      }
      $subsectionsLi.show();
      $accordionSections.filter('[data-section-index="' + sectionIdx + '"]').show();
    });

    function handleAccordionToggle(details) {
      var $details = $(details);
      var subsectionId = $details.data('subsection-id');

      // Enforce a single-open accordion within the visible section.
      if (details.open) {
        $details.closest('.accordion-section').find('details.accordion-item').not(details).prop('open', false);
      }

      if (details.open) {
        if ($queryInput.length) $queryInput.val(subsectionId);
        // Only show the submit UI + form when this subsection opts in.
        var showForm = String($details.data('show-form')) === '1';
        var requiresSection3Details = String(subsectionId) === '2';
        if (showForm) {
          $readAnswer.show();
          if ($reportFormBlock.length) {
            var $host = $details.find('.report_form_host').first();
            if ($host.length) {
              $reportFormBlock.appendTo($host).show();
            } else {
              $reportFormBlock.hide();
            }
          }
          // Attach last clicked scan URL (if we have it) to the form submission.
          if ($scanUrlInput.length) {
            var recordId = $('input[name="contact[record_id]"]').val() || 'default';
            var lastScanUrlKey = 'best_guess_last_scan_url_' + recordId;
            var lastScanUrl = null;
            try { lastScanUrl = sessionStorage.getItem(lastScanUrlKey); } catch (e) { lastScanUrl = null; }
            if (lastScanUrl) $scanUrlInput.val(lastScanUrl);
          }
          setSection3RequiredState(requiresSection3Details);
        } else {
          $readAnswer.hide();
          $('#read_explanation').prop('checked', false);
          if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
          setSection3RequiredState(false);
        }
      } else {
        // If the user closes the currently-selected subsection, clear selection UI.
        if ($queryInput.length && String($queryInput.val()) === String(subsectionId)) {
          $queryInput.val('');
          $readAnswer.hide();
          $('#read_explanation').prop('checked', false);
          if ($reportFormBlock.length) $reportFormBlock.hide().appendTo('body');
          setSection3RequiredState(false);
        }
      }

      // Show/hide the corrections table based on per-subsection flag.
      if ($correctionsBlock.length) {
        var showFormForCorrections = String($details.data('show-form')) === '1';
        if (details.open && showFormForCorrections) {
          $correctionsBlock.show();
        } else {
          $correctionsBlock.hide();
        }
      }
    }

    // 'toggle' on <details> does not reliably bubble; bind directly.
    $('details.accordion-item').each(function() {
      this.addEventListener('toggle', function() { handleAccordionToggle(this); });
    });

    // Keep existing behaviour: checkbox can collapse/expand the form if shown.
    $('#read_explanation').change(function() {
      if ($reportFormBlock.length) $reportFormBlock.toggle();
    });
  });
</script>