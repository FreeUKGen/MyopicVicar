<%# locals: rows, variant: :app (default) | :email — horizontal: fields as columns, "As shown" / "User correction" as rows %>
<% variant ||= :app %>
<% is_email = (variant == :email) %>
<% rows_arr = Array(rows).map { |r| r.stringify_keys } %>
<div style="overflow-x:auto;max-width:100%;">
  <table class="table--bordered table--data table--left-aligned freebmd-field-report-table" style="width:100%;max-width:100%;border-collapse:collapse;">
    <thead>
      <tr>
        <th scope="col" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;background:#f5f5f5;"></th>
        <% rows_arr.each do |r| %>
          <th scope="col" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;background:#f5f5f5;"><%= r['field'] %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <tr>
        <th scope="row" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;background:#f9f9f9;white-space:nowrap;">As shown</th>
        <% rows_arr.each do |r| %>
          <td style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;vertical-align:top;"><%= r['current'] %></td>
        <% end %>
      </tr>
      <tr class="freebmd-report-horizontal-corrections">
        <th scope="row" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;background:#f9f9f9;white-space:nowrap;">User correction</th>
        <% rows_arr.each do |r| %>
          <% corrected = r['corrected'] == true || r['corrected'].to_s == 'true' %>
          <td class="<%= 'freebmd-report-hcell--corrected' if corrected %>"
              style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;vertical-align:top;<%= 'color:#9b1c1c;font-weight:600;background:#fff5f5;' if is_email && corrected %>">
            <% if corrected %>
              <%= r['correction'] %>
            <% else %>
              &mdash;
            <% end %>
          </td>
        <% end %>
      </tr>
    </tbody>
  </table>
</div>
<% unless is_email %>
  <style>
    .freebmd-field-report-table .freebmd-report-hcell--corrected {
      color: #9b1c1c;
      font-weight: 600;
      background: #fff5f5;
    }
  </style>
<% end %>
