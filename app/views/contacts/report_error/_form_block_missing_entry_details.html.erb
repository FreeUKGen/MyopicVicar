<%# FreeBMD report_error — form_numbers: 3 (missing entry grid). Toggled via #section3_required_fields_block in report_error JS. %>
<div id="section3_required_fields_block" style="display: none;" class="push--bottom">
  <h3 class="gamma push-half--bottom">Details for missing entry (optional — provide what you can)</h3>
  <p id="section3_help" class="help-text push-half--bottom">Fields follow whatever appears on your index page. Choose <strong>Event</strong> first: extra columns for <strong>birth and death</strong> (Registered, entry/line) appear only for those events; <strong>marriage</strong> uses district, volume, page, and spouse where relevant. Leave any field blank if that column is not on your scan.</p>
  <ol class="grid">
    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_surname">Surname</label>
      <input id="section3_surname" name="contact[session_data][section3][surname]" type="text" class="text-input section3-required-field" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole clear--left">
      <label class="label" for="section3_forename">Given Name</label>
      <input id="section3_forename" name="contact[session_data][section3][forename]" type="text" class="text-input section3-required-field" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_event">Record Type</label>
      <select id="section3_event" name="contact[session_data][section3][event]" class="text-input section3-required-field" aria-describedby="section3_help">
        <option value="">Please select</option>
        <option value="Birth">Birth</option>
        <option value="Death">Death</option>
        <option value="Marriage">Marriage</option>
      </select>
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_year">Year</label>
      <input id="section3_year" name="contact[session_data][section3][year]" type="text" class="text-input section3-required-field" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="e.g. 1891" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_quarter">Quarter (if relevant)</label>
      <select id="section3_quarter" name="contact[session_data][section3][quarter]" class="text-input" aria-describedby="section3_help">
        <option value="">Not applicable</option>
        <option value="Mar">Mar</option>
        <option value="Jun">Jun</option>
        <option value="Sep">Sep</option>
        <option value="Dec">Dec</option>
      </select>
    </li>

    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-birth" style="display: none;">
      <label class="label" for="section3_mothers_maiden_name">Mother's maiden name</label>
      <input id="section3_mothers_maiden_name" name="contact[session_data][section3][mothers_maiden_name]" type="text" class="text-input" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-death" style="display: none;">
      <label class="label" for="section3_age_or_dob">Age at death / date of birth</label>
      <input id="section3_age_or_dob" name="contact[session_data][section3][age_or_dob]" type="text" class="text-input" placeholder="As on index" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-marriage" style="display: none;">
      <label class="label" for="section3_spouse_name">Spouse name</label>
      <input id="section3_spouse_name" name="contact[session_data][section3][spouse_name]" type="text" class="text-input" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_volume">Volume</label>
      <input id="section3_volume" name="contact[session_data][section3][volume]" type="text" class="text-input" aria-describedby="section3_help">
    </li>

    <li class="grid__item one-quarter lap-one-half palm-one-whole">
      <label class="label" for="section3_page_number">Page number</label>
      <input id="section3_page_number" name="contact[session_data][section3][page_number]" type="text" class="text-input" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-registered-extra" style="display: none;">
      <label class="label" for="section3_registered">Registered</label>
      <input id="section3_registered" name="contact[session_data][section3][registered]" type="text" class="text-input" placeholder="As on index (when shown)" aria-describedby="section3_help">
    </li>

    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-marriage1994" style="display: none;">
      <label class="label" for="section3_marriage_entry">Marriage submission — entry number</label>
      <input id="section3_marriage_entry" name="contact[session_data][section3][marriage_submission_entry_number]" type="text" class="text-input" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-marriage1994" style="display: none;">
      <label class="label" for="section3_marriage_source">Marriage submission — SourceCode</label>
      <input id="section3_marriage_source" name="contact[session_data][section3][marriage_submission_source_code]" type="text" class="text-input" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-quarter lap-one-half palm-one-whole section3-if-marriage1994" style="display: none;">
      <label class="label" for="section3_marriage_registered">Marriage submission — Registered</label>
      <input id="section3_marriage_registered" name="contact[session_data][section3][marriage_submission_registered]" type="text" class="text-input" placeholder="As on index" aria-describedby="section3_help">
    </li>
    <li class="grid__item one-whole lap-one-whole palm-one-whole push-half--top clear--left">
      <label class="label" for="section3_district">District</label>
      <input id="section3_district" name="contact[session_data][section3][district]" type="text" class="text-input section3-required-field" aria-describedby="section3_help">
    </li>

    <li class="grid__item one-whole push-half--top">
      <label for="section3_multiple_entries">
        <input id="section3_multiple_entries" type="checkbox" name="contact[session_data][section3][multiple_entries]" value="1" class="section3-required-checkbox">
        Multiple entries
      </label>
    </li>
  </ol>
</div>
