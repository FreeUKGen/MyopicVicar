<% breadcrumb :show_contact, @contact %>
<div style="clear:both;"> </div>
<%= render "flash_notice" %>
<div class="text--center push--bottom">
  <%= link_to 'Edit Contact', edit_contact_path(@contact), class: "btn btn--small" unless @contact.github_issue_url.present? %>
</div>
<h4 class=" text--center push--bottom" ><%= show_contact_title(@contact) %></h4>
<h4 class=" text--center push--bottom" ><%= show_contact_title_line_two(@contact) %></h4>
<% if !Contact.github_enabled %>
  <h4 class=" text--center">GitHub integration is not activated </h4>
<% end%>
<%= render 'show_nav' %>
<div class="grid" >
  <section class="island ">
    <div class="grid__item ">
      <table class="table--bordered table--data " style="text-align: left">
        <colgroup >
          <col class=t20>
          <col class=t80>
        </colgroup>
        <tr>
          <th class="caps">Field</th>
          <th  class="caps">Value</th>
        </tr>
        <%= render 'show_data_problem' if @contact.contact_type == 'Data Problem' && (@contact.entry_id.present? || (appname_downcase == 'freebmd' && @contact.record_id.present?)) %>
        <%= render 'show_actor' %>
        <% if appname_downcase == 'freebmd' && @contact.contact_type == 'Data Problem' %>
          <% if freebmd_field_report_rows(@contact).present? %>
            <tr>
              <td colspan="2">
                <h3 class="gamma push-half--bottom">Original entry</h3>
                <p class="push-half--bottom">Index line as shown on FreeBMD; user corrections highlighted in the third column where supplied.</p>
                <%= render 'contacts/freebmd_field_report_table', rows: freebmd_field_report_rows(@contact) %>
              </td>
            </tr>
          <% end %>
          <% if freebmd_missing_entry_rows(@contact).present? %>
            <tr>
              <td colspan="2">
                <h3 class="gamma push-half--bottom">Missing entry (as submitted on the form)</h3>
                <p class="push-half--bottom">Details supplied for a missing or related index entry.</p>
                <%= render 'contacts/freebmd_missing_entry_table', rows: freebmd_missing_entry_rows(@contact) %>
              </td>
            </tr>
          <% end %>
        <% end %>
        <tr >
          <td style="vertical-align: top;">The explanation was:</td>
          <td class="weight--semibold"><%= format_contact_body_for_display(@contact) %></td>
        </tr>
        <tr >
          <td >Recorded problem page URL:</td>
          <td class="weight--semibold"><%= @contact.problem_page_url %></td>
        </tr>
        <tr >
          <td >Record URL:</td>
          <td class="weight--semibold">
            <% if @contact.record_url.present? %>
              <%= link_to @contact.record_url, @contact.record_url, target: '_blank', rel: 'noopener noreferrer' %>
            <% else %>
              &ndash;
            <% end %>
          </td>
        </tr>
        <% if @contact.github_issue_url %>
          <tr>
            <td>Github Issue:</td>
            <td class="weight--semibold"> <%= link_to @contact.github_issue_url, @contact.github_issue_url  %></td>
          </tr>
          <tr>
            <td>Github Number:</td>
            <td class="weight--semibold"> <%= @contact.github_number  %></td>
          </tr>
          <tr>
            <td>Make Github Comment:</td>
            <td class="weight--semibold"> <%= link_to @contact.github_comment_url, @contact.github_comment_url  %></td>
          </tr>
        <% end %>
      </table>
      <% if @contact.screenshot_url %>
        <%= image_tag @contact.screenshot_url %>
      <% end %>
    </div>
  </section>
</div>