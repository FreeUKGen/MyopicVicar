<% breadcrumb :show_contact, @contact %>
<div style="clear:both;"> </div>
<%= render "flash_notice" %>
<h4 class=" text--center push--bottom" ><%= show_contact_title(@contact) %></h4>
<h4 class=" text--center push--bottom" ><%= show_contact_title_line_two(@contact) %></h4>
<% if !Contact.github_enabled %>
  <h4 class=" text--center">GitHub integration is not activated </h4>
<% end%>
<%= render 'show_nav' %>
<div class="grid" >
  <section class="island ">
    <div class="grid__item ">
      <table class="table--bordered table--data " style="text-align: left">
        <colgroup >
          <col class=t20>
          <col class=t80>
        </colgroup>
        <tr>
          <th class="caps">Field</th>
          <th  class="caps">Value</th>
        </tr>
        <%= render 'show_data_problem' if @contact.contact_type == 'Data Problem' &&  @contact.entry_id.present?%>
        <%= render 'show_actor' %>
        <tr >
          <td >The explanation was:</td>
          <td class="weight--semibold"><%= @contact.body %></td>
        </tr>
        <% if @contact.session_data.present? %>
          <tr>
            <td>Session data:</td>
            <td class="weight--semibold">
              <pre style="white-space: pre-wrap;"><%= JSON.pretty_generate(@contact.session_data) rescue @contact.session_data.inspect %></pre>
            </td>
          </tr>
        <% end %>
        <% if @contact.github_issue_url %>
          <tr>
            <td>Github Issue:</td>
            <td class="weight--semibold"> <%= link_to @contact.github_issue_url, @contact.github_issue_url  %></td>
          </tr>
          <tr>
            <td>Github Number:</td>
            <td class="weight--semibold"> <%= @contact.github_number  %></td>
          </tr>
          <tr>
            <td>Make Github Comment:</td>
            <td class="weight--semibold"> <%= link_to @contact.github_comment_url, @contact.github_comment_url  %></td>
          </tr>
        <% end %>
        <% if @contact.attachments_present? %>
          <tr>
            <td>Attachment</td>
            <td class="weight--semibold">
              <% @contact.attachment_urls.each do |url| %>
                <div class="push--bottom">
                  <%= link_to url, url, target: '_blank', rel: 'noopener' %>
                  <div class="push--top"><%= image_tag url, alt: 'Contact attachment' %></div>
                </div>
              <% end %>
            </td>
          </tr>
        <% elsif @contact.screenshot_location.present? %>
          <tr>
            <td>Attachment</td>
            <td class="weight--semibold">An attachment was recorded but the file is not available on this server. Put the file at <code>public/<%= @contact.screenshot_location %></code> or in <code>public/uploads/contact/screenshots/<%= @contact.id %>/</code> then reload this page.</td>
          </tr>
        <% end %>
      </table>
    </div>
  </section>
</div>