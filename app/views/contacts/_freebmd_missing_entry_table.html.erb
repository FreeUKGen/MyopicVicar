<%# locals: rows (array of { 'field' => ..., 'value' => ... }), variant (optional, for future email-specific tweaks) %>
<table class="table--bordered table--data table--left-aligned freebmd-missing-entry-table" style="width:100%;max-width:48rem;border-collapse:collapse;">
  <thead>
    <tr>
      <th style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;">Field</th>
      <th style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;">Value submitted</th>
    </tr>
  </thead>
  <tbody>
    <% Array(rows).each do |r| %>
      <% r = r.stringify_keys %>
      <tr>
        <th scope="row" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;"><%= r['field'] %></th>
        <td style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;"><%= r['value'] %></td>
      </tr>
    <% end %>
  </tbody>
</table>
