<%# locals: rows — horizontal: one header row (field names), one data row (values). No correction column. %>
<% rows_arr = Array(rows).map { |r| r.stringify_keys } %>
<div style="overflow-x:auto;max-width:100%;">
  <table class="table--bordered table--data table--left-aligned freebmd-missing-entry-table" style="width:100%;max-width:100%;border-collapse:collapse;">
    <thead>
      <tr>
        <% rows_arr.each do |r| %>
          <th scope="col" style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;background:#f5f5f5;"><%= r['field'] %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <tr>
        <% rows_arr.each do |r| %>
          <td style="text-align:left;border:1px solid #ccc;padding:0.35rem 0.5rem;vertical-align:top;"><%= r['value'] %></td>
        <% end %>
      </tr>
    </tbody>
  </table>
</div>
