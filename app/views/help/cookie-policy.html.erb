  <% else %>
    <h1 id="body_content_title">Cookie Policy</h1>
    <div class="grid">
      <div class="grid__item three-fifths lap-three-quarters palm-one-whole">
        <p>For how we use cookies, see
          <a href="https://www.freeukgenealogy.org.uk/about/cookies/">Free UK Genealogy — cookies</a>.</p>
      </div>
    </div>
  <% end %>
</section>
