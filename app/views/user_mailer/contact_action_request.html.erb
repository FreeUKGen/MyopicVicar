<p> Dear <%= @send_to.person_forename %>;</p>
<p>We have received correspondence <%= @contact.identifier %> from <%= @contact.name %> email <%= @contact.email_address %> at <%= @contact.contact_time.strftime("%H:%M on %F") unless @contact.contact_time.nil?%>. </p>
<p>You are requested to take action on the correspondence preferably using the on-line contact system</p>
<% unless @cc_names.blank? %>
  <p>Copies of the action request were sent to the following. Please include them in any correspondence<br>
    <%  @cc_names.each do |copy| %>
      <%= copy%>
    <% end%>
  </p>
<% end%>
<p>The following is the information submitted.</p>
<p>  <b><%= @contact.contact_type %>:</b></p>
<% if @appname.downcase == 'freebmd' && @contact.session_data.is_a?(Hash) && @contact.session_data['freebmd_field_report'].present? %>
  <% missing_entry_report = freebmd_missing_entry_rows(@contact).present? %>
  <% if missing_entry_report %>
    <p><b>Original entry</b> — columns are fields; row shown: &ldquo;As shown&rdquo;.</p>
  <% else %>
    <p><b>Original entry</b> — columns are fields; first data row &ldquo;As shown&rdquo;, second row &ldquo;User correction&rdquo; (highlighted where supplied):</p>
  <% end %>
  <%= render partial: 'contacts/freebmd_field_report_table', locals: { rows: @contact.session_data['freebmd_field_report'], variant: :email, show_corrections: !missing_entry_report } %>
<% end %>
<% if @appname.downcase == 'freebmd' && @contact.session_data.is_a?(Hash) && freebmd_missing_entry_rows(@contact).present? %>
  <p><b>Missing entry</b> (as submitted on the form):</p>
  <%= render partial: 'contacts/freebmd_missing_entry_table', locals: { rows: freebmd_missing_entry_rows(@contact) } %>
<% end %>
<div style="white-space:pre-wrap;word-wrap:break-word;font-family:system-ui,Segoe UI,sans-serif;font-size:14px;line-height:1.45;max-width:48rem;"><%= @contact.body %></div>
<% if @contact.contact_type == 'Data Problem' &&  @contact.entry_id.present?%>
  <p><a href="<%=Rails.application.config.website%>/freereg1_csv_entries/<%=@contact.entry_id%>"> <%=@contact.line_id %> </a></p>
<% end%>
<% if @appname.downcase == 'freecen'%>
  <% if @communication.contact_type == 'Data Problem'%>
    <%= render 'cen_coordinator_data_problem'%>
  <% end %>
<% end %>
<p>
  <% if @contact.screenshot_url.present?%>
    <p>An image/attachment is provided</p>
  <% end%></p>
<p>The <%= @appname %> Team</p>
</p>