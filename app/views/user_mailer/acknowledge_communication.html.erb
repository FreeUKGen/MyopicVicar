<p> Dear <%= @communication.name %>;</p>
<p>PLEASE DO NOT REPLY TO THIS EMAIL. Thank you for your correspondence at <%= @communication.contact_time.strftime("%H:%M on %F") unless @communication.contact_time.nil?%>. Please quote the following number <%= @communication.identifier %> in any subsequent communication with us on this matter.</p>
<p>A member of our team should be in touch as soon as we can.</p>
<p>The following is the information you submitted.</p>
<p>  <b><%= @communication.contact_type %>:</b></p>
<% if @appname.downcase == 'freebmd' && @communication.session_data.is_a?(Hash) && @communication.session_data['freebmd_field_report'].present? %>
  <% missing_entry_report = freebmd_missing_entry_rows(@communication).present? %>
  <% if missing_entry_report %>
    <p><b>Original entry</b> — columns are fields; row shown: &ldquo;As shown&rdquo;.</p>
  <% else %>
    <p><b>Original entry</b> — columns are fields; first data row &ldquo;As shown&rdquo;, second row &ldquo;User correction&rdquo; (highlighted where supplied):</p>
  <% end %>
  <%= render partial: 'contacts/freebmd_field_report_table', locals: { rows: @communication.session_data['freebmd_field_report'], variant: :email, show_corrections: !missing_entry_report } %>
<% end %>
<% if @appname.downcase == 'freebmd' && @communication.session_data.is_a?(Hash) && freebmd_missing_entry_rows(@communication).present? %>
  <p><b>Missing entry</b> (as submitted on the form):</p>
  <%= render partial: 'contacts/freebmd_missing_entry_table', locals: { rows: freebmd_missing_entry_rows(@communication) } %>
<% end %>
<div style="white-space:pre-wrap;word-wrap:break-word;font-family:system-ui,Segoe UI,sans-serif;font-size:14px;line-height:1.45;max-width:48rem;"><%= @communication.body %></div>
<% if @appname.downcase == 'freecen'%>
  <% if @communication.contact_type == 'Data Problem'%>
    <%= render 'cen_coordinator_data_problem'%>
  <% end %>
<% end %>
<% if @communication.screenshot_url.present?%>
  <p>A copy of any attachment is provided.</p>
<% end%>
<p>The <%= @appname %> Team</p>